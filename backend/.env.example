# ============================================================================
# ATS Resume Checker — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values you want to use.
# Only set ONE AI_PROVIDER and its matching credentials.
#
# Usage:
#   cp .env.example .env
#   # Uncomment your chosen provider, add API key, set AI_PROVIDER
# ============================================================================


# ── Active Provider ──────────────────────────────────────────────────────────
# Set this to the provider you want to use. Must match one of the sections below.
# Options: openai | anthropic | google | cloudflare | mistral | ollama | nvidia
AI_PROVIDER=openai


# ── Database & Storage ───────────────────────────────────────────────────────
# DB_PATH=./data/ats_platform.db          # SQLite path (default: auto-detected)
# UPLOADS_PATH=./uploads                   # Resume upload directory


# ============================================================================
# PROVIDER 1: OpenAI  (https://platform.openai.com)
# ============================================================================
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# Available models:
#   gpt-4o            - Most capable, highest cost
#   gpt-4o-mini       - Fast, cheap, recommended default
#   gpt-3.5-turbo     - Legacy, lower cost


# ============================================================================
# PROVIDER 2: Anthropic / Claude  (https://console.anthropic.com)
# ============================================================================
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
#
# Available models:
#   claude-opus-4-5              - Most capable
#   claude-sonnet-4-5            - Balanced performance
#   claude-3-5-haiku-20241022    - Fastest, cheapest


# ============================================================================
# PROVIDER 3: Google Generative AI / Gemini  (https://aistudio.google.com)
# ============================================================================
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-1.5-flash
#
# Available models:
#   gemini-1.5-pro               - Best quality
#   gemini-1.5-flash             - Fast and cost-efficient
#   gemini-2.0-flash             - Latest flash model


# ============================================================================
# PROVIDER 4: Cloudflare AI  (https://developers.cloudflare.com/workers-ai)
# Includes GLM-4 (Zhipu AI), Llama, Mistral, and 60+ models
# ============================================================================
# CLOUDFLARE_API_TOKEN=...
# CLOUDFLARE_ACCOUNT_ID=...
# CLOUDFLARE_MODEL=@cf/meta/llama-3.1-8b-instruct
#
# Available models (GLM / others):
#   @cf/thudm/chatglm-6b-chat    - GLM-6B (Zhipu AI)
#   @cf/meta/llama-3.1-8b-instruct
#   @cf/mistral/mistral-7b-instruct-v0.2
#   @cf/qwen/qwen1.5-14b-chat-awq
# Cloudflare AI base URL is auto-constructed from account ID.


# ============================================================================
# PROVIDER 5: Mistral AI  (https://console.mistral.ai)
# ============================================================================
# MISTRAL_API_KEY=...
# MISTRAL_MODEL=mistral-small-latest
#
# Available models:
#   mistral-large-latest         - Best quality
#   mistral-small-latest         - Fast, cheap
#   codestral-latest             - Code-focused


# ============================================================================
# PROVIDER 6: Ollama (local, no API key needed)  (https://ollama.ai)
# ============================================================================
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2
#
# Run locally: `ollama pull llama3.2 && ollama serve`
# Popular models: llama3.2, mistral, gemma2, phi3, qwen2.5


# ============================================================================
# PROVIDER 7: NVIDIA NIM  (https://build.nvidia.com)
# ============================================================================
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct
#
# Available models:
#   meta/llama-3.1-8b-instruct   - Default, fast
#   meta/llama-3.1-70b-instruct  - Better quality
#   microsoft/phi-3-small-128k-instruct
#   mistralai/mistral-7b-instruct-v0.3


# ============================================================================
# PROVIDER 8: OpenRouter  (https://openrouter.ai) — access 200+ models
# ============================================================================
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
#
# Popular models:
#   meta-llama/llama-3.1-8b-instruct:free
#   google/gemma-2-9b-it:free
#   mistralai/mistral-7b-instruct:free


# ============================================================================
# Feature Flags
# ============================================================================
# AI_TIMEOUT=30                  # Seconds before AI call times out
# AI_MAX_TOKENS=2048             # Max tokens per completion
# ENABLE_AI_FEEDBACK=true        # Enable AI-generated feedback text
# ENABLE_AI_VERDICT=true         # Enable AI role-fit verdict
