{
  "_metadata": {
    "description": "Certification regex patterns for detection in resume text",
    "version": "1.0.0"
  },
  "data": [
    {"canonical_name": "CompTIA Security+", "pattern": "(?i)(?:comptia\\s+)?security\\s*\\+"},
    {"canonical_name": "CompTIA Network+", "pattern": "(?i)(?:comptia\\s+)?network\\s*\\+"},
    {"canonical_name": "CompTIA A+", "pattern": "(?i)comptia\\s+a\\s*\\+"},
    {"canonical_name": "CompTIA CySA+", "pattern": "(?i)(?:comptia\\s+)?cysa\\s*\\+"},
    {"canonical_name": "CompTIA CASP+", "pattern": "(?i)(?:comptia\\s+)?casp\\s*\\+"},
    {"canonical_name": "CompTIA PenTest+", "pattern": "(?i)(?:comptia\\s+)?pentest\\s*\\+"},
    {"canonical_name": "CISSP", "pattern": "(?i)\\b(?:cissp|certified\\s+information\\s+systems?\\s+security\\s+professional)\\b"},
    {"canonical_name": "CISM", "pattern": "(?i)\\b(?:cism|certified\\s+information\\s+security\\s+manager)\\b"},
    {"canonical_name": "CISA", "pattern": "(?i)\\b(?:cisa|certified\\s+information\\s+systems?\\s+auditor)\\b"},
    {"canonical_name": "CEH", "pattern": "(?i)\\b(?:ceh|certified\\s+ethical\\s+hacker|ec-?council)\\b"},
    {"canonical_name": "OSCP", "pattern": "(?i)\\b(?:oscp|offensive\\s+security\\s+certified\\s+professional)\\b"},
    {"canonical_name": "OSWE", "pattern": "(?i)\\b(?:oswe|offensive\\s+security\\s+web\\s+expert)\\b"},
    {"canonical_name": "OSCE", "pattern": "(?i)\\b(?:osce|offensive\\s+security\\s+certified\\s+expert)\\b"},
    {"canonical_name": "GIAC GSEC", "pattern": "(?i)\\b(?:gsec|giac\\s+security\\s+essentials)\\b"},
    {"canonical_name": "GIAC GCIH", "pattern": "(?i)\\b(?:gcih|giac\\s+certified\\s+incident\\s+handler)\\b"},
    {"canonical_name": "GIAC GCIA", "pattern": "(?i)\\b(?:gcia|giac\\s+certified\\s+intrusion\\s+analyst)\\b"},
    {"canonical_name": "GIAC GPEN", "pattern": "(?i)\\b(?:gpen|giac\\s+penetration\\s+tester)\\b"},
    {"canonical_name": "GIAC GREM", "pattern": "(?i)\\b(?:grem|giac\\s+reverse\\s+engineering\\s+malware)\\b"},
    {"canonical_name": "AWS Certified Solutions Architect", "pattern": "(?i)aws\\s+(?:certified\\s+)?solutions?\\s+architect"},
    {"canonical_name": "AWS Certified Security Specialty", "pattern": "(?i)aws\\s+(?:certified\\s+)?security\\s+(?:specialty|speciality)"},
    {"canonical_name": "AWS Certified Cloud Practitioner", "pattern": "(?i)aws\\s+(?:certified\\s+)?cloud\\s+practitioner"},
    {"canonical_name": "Azure Security Engineer", "pattern": "(?i)azure\\s+security\\s+engineer|az-?500"},
    {"canonical_name": "Azure Administrator", "pattern": "(?i)azure\\s+administrator|az-?104"},
    {"canonical_name": "Google Cloud Security", "pattern": "(?i)google\\s+(?:cloud\\s+)?(?:professional\\s+)?(?:cloud\\s+)?security"},
    {"canonical_name": "CCNA", "pattern": "(?i)\\bccna\\b|cisco\\s+certified\\s+network\\s+associate"},
    {"canonical_name": "CCNP", "pattern": "(?i)\\bccnp\\b|cisco\\s+certified\\s+network\\s+professional"},
    {"canonical_name": "CCIE", "pattern": "(?i)\\bccie\\b|cisco\\s+certified\\s+internetwork\\s+expert"},
    {"canonical_name": "PMP", "pattern": "(?i)\\bpmp\\b|project\\s+management\\s+professional"},
    {"canonical_name": "ITIL Foundation", "pattern": "(?i)itil\\s+(?:v[34]\\s+)?foundation|itil\\s+certified"},
    {"canonical_name": "Certified Kubernetes Administrator", "pattern": "(?i)\\bcka\\b|certified\\s+kubernetes\\s+administrator"},
    {"canonical_name": "Certified Kubernetes Security Specialist", "pattern": "(?i)\\bcks\\b|certified\\s+kubernetes\\s+security"},
    {"canonical_name": "Splunk Certified", "pattern": "(?i)splunk\\s+(?:certified|core\\s+certified)"},
    {"canonical_name": "CRISC", "pattern": "(?i)\\bcrisc\\b|certified\\s+in\\s+risk"},
    {"canonical_name": "CCSP", "pattern": "(?i)\\bccsp\\b|certified\\s+cloud\\s+security\\s+professional"},
    {"canonical_name": "SOC Analyst Certification", "pattern": "(?i)soc\\s+analyst|certified\\s+soc\\s+analyst|csa"},
    {"canonical_name": "eJPT", "pattern": "(?i)\\bejpt\\b|elearn\\s+junior\\s+penetration\\s+tester"},
    {"canonical_name": "eCPPT", "pattern": "(?i)\\becppt\\b"},
    {"canonical_name": "BTL1", "pattern": "(?i)\\bbtl1\\b|blue\\s+team\\s+level\\s+1"},
    {"canonical_name": "BTL2", "pattern": "(?i)\\bbtl2\\b|blue\\s+team\\s+level\\s+2"}
  ]
}
