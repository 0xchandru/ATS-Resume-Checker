# ============================================================================
# ATS Resume Checker — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# Uncomment ONLY the provider section you want to use, set AI_PROVIDER to
# match, and add your API key. All other sections should remain commented out.
#
#   cp .env.example .env
#   # edit .env → set AI_PROVIDER and uncomment your provider block
# ============================================================================

# Tells your IDE (like VS Code) where to find the Python 'app' module
PYTHONPATH=./backend

# The port the FastAPI backend runs on
PORT=8080

# ── Active AI Provider ───────────────────────────────────────────────────────
# Must match one of: openai | anthropic | google | cloudflare | mistral
#                    ollama | nvidia | openrouter
AI_PROVIDER=nvidia


── Database & Storage ───────────────────────────────────────────────────────
DB_PATH=./data/ats_platform.db
UPLOADS_PATH=./uploads
MAX_UPLOAD_MB=10


# ============================================================================
# PROVIDER 1 — OpenAI  (https://platform.openai.com)
# ============================================================================
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# Recommended models:
#   gpt-4o             — Most capable, best for complex analysis
#   gpt-4o-mini        — Fast, cost-efficient default (recommended)
#   gpt-4-turbo        — Strong reasoning, larger context


# ============================================================================
# PROVIDER 2 — Anthropic / Claude  (https://console.anthropic.com)
# ============================================================================
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022
#
# Recommended models:
#   claude-opus-4-5            — Highest capability
#   claude-sonnet-4-5          — Balanced performance/cost
#   claude-3-5-haiku-20241022  — Fastest, cheapest


# ============================================================================
# PROVIDER 3 — Google Generative AI / Gemini  (https://aistudio.google.com)
# ============================================================================
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODEL=gemini-1.5-flash
#
# Recommended models:
#   gemini-2.0-flash           — Latest flash (fast, cost-efficient)
#   gemini-1.5-pro             — Best reasoning quality
#   gemini-1.5-flash           — Fast and balanced
#   gemini-2.0-flash-thinking  — Chain-of-thought reasoning


# ============================================================================
# PROVIDER 4 — Cloudflare Workers AI  (https://developers.cloudflare.com/workers-ai)
# Includes GLM (Zhipu AI), Llama, Mistral, Qwen, and 60+ models.
# CLOUDFLARE_ACCOUNT_ID is found in your Cloudflare dashboard (right sidebar).
# ============================================================================
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_MODEL=@cf/zhipu-ai/glm-5.2
#
# GLM models (Zhipu AI — Chinese + English):
#   @cf/thudm/chatglm-6b-chat          — GLM-6B Chat (fast)
#   @hf/thudm/chatglm3-6b              — ChatGLM3-6B (improved)
#
# Llama models:
#   @cf/meta/llama-3.1-8b-instruct     — Llama 3.1 8B (default)
#   @cf/meta/llama-3.1-70b-instruct    — Llama 3.1 70B (stronger)
#   @cf/meta/llama-3.2-3b-instruct     — Llama 3.2 3B (lightest)
#
# Mistral models:
#   @cf/mistral/mistral-7b-instruct-v0.2
#
# Qwen models:
#   @cf/qwen/qwen1.5-14b-chat-awq
#   @cf/qwen/qwen1.5-7b-chat-awq
#
# Note: Base URL is auto-constructed as:
#   https://api.cloudflare.com/client/v4/accounts/{CLOUDFLARE_ACCOUNT_ID}/ai/v1


# ============================================================================
# PROVIDER 5 — Mistral AI  (https://console.mistral.ai)
# ============================================================================
# MISTRAL_API_KEY=...
# MISTRAL_MODEL=mistral-small-latest
#
# Recommended models:
#   mistral-large-latest       — Best quality
#   mistral-small-latest       — Fast and cheap (recommended)
#   codestral-latest           — Code-optimised
#   open-mistral-nemo          — Open-weight, strong reasoning


# ============================================================================
# PROVIDER 6 — Ollama  (local inference, no API key needed)
# Install: https://ollama.ai  |  Pull: ollama pull llama3.2
# ============================================================================
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2
#
# Popular models to pull locally:
#   llama3.2          — Meta Llama 3.2 (recommended)
#   mistral           — Mistral 7B
#   gemma2            — Google Gemma 2 9B
#   phi3              — Microsoft Phi-3
#   qwen2.5           — Alibaba Qwen 2.5
#   deepseek-r1       — DeepSeek R1 reasoning model


# ============================================================================
# PROVIDER 7 — NVIDIA NIM  (https://build.nvidia.com)
# Free tier available — no credit card needed for the inference API.
# ============================================================================
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_MODEL=meta/llama-3.1-8b-instruct
#
# Recommended models:
#   meta/llama-3.1-8b-instruct        — Default, fast, free tier
#   meta/llama-3.1-70b-instruct       — Better quality, free tier
#   meta/llama-3.3-70b-instruct       — Latest 70B
#   mistralai/mistral-large-2-instruct — Mistral Large
#   microsoft/phi-3-small-128k-instruct


# ============================================================================
# PROVIDER 8 — OpenRouter  (https://openrouter.ai)
# Access 200+ models from one API endpoint — GPT-4o, Claude, Gemini, and more.
# ============================================================================
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
#
# Free models (no cost):
#   meta-llama/llama-3.1-8b-instruct:free
#   google/gemma-2-9b-it:free
#   mistralai/mistral-7b-instruct:free
#   microsoft/phi-3-mini-128k-instruct:free
#   qwen/qwen-2-7b-instruct:free
#
# Paid models via OpenRouter:
#   openai/gpt-4o
#   anthropic/claude-3-5-sonnet
#   google/gemini-1.5-pro
#   meta-llama/llama-3.1-405b-instruct


# ============================================================================
# Feature Flags  (all optional)
# ============================================================================
# AI_TIMEOUT=30              # Seconds before AI call times out (default: 30)
# AI_MAX_TOKENS=2048         # Max tokens per completion (default: 2048)
# ENABLE_AI_FEEDBACK=true    # AI-generated section feedback (default: true)
# ENABLE_AI_VERDICT=true     # AI role-fit verdict (default: true)
